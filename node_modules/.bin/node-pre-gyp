#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*) basedir=`cygpath -w "$basedir"`;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/e/Web/Yuan/yuan-server/node_modules/node-pre-gyp/bin/node_modules:/mnt/e/Web/Yuan/yuan-server/node_modules/node-pre-gyp/node_modules:/mnt/e/Web/Yuan/yuan-server/node_modules:/mnt/e/Web/Yuan/node_modules:/mnt/e/Web/node_modules:/mnt/e/node_modules:/mnt/e/Web/Yuan/yuan-server/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/e/Web/Yuan/yuan-server/node_modules/node-pre-gyp/bin/node_modules:/mnt/e/Web/Yuan/yuan-server/node_modules/node-pre-gyp/node_modules:/mnt/e/Web/Yuan/yuan-server/node_modules:/mnt/e/Web/Yuan/node_modules:/mnt/e/Web/node_modules:/mnt/e/node_modules:/mnt/e/Web/Yuan/yuan-server/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node-pre-gyp/bin/node-pre-gyp" "$@"
else
  exec node  "$basedir/../node-pre-gyp/bin/node-pre-gyp" "$@"
fi
